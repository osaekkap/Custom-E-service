// ============================================================
// Customs-Edoc — Prisma Schema v2.1
// Multi-tenant + กศก.101/1 + ebXML NSW Connector fields
// Updated: Phase 1 W1-T5 — init_multitenant_gsk101_ebxml
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN  // Service provider (you)
  TENANT_ADMIN // Factory admin
  USER         // Factory staff
  VIEWER       // Read-only
}

enum CustomerStatus {
  ACTIVE
  TRIAL
  SUSPENDED
}

enum BillingType {
  PER_JOB
  TERM
}

enum JobType {
  EXPORT
  IMPORT
}

enum JobStatus {
  DRAFT
  PREPARING        // Documents uploaded, AI extraction in progress
  READY            // Extraction complete, HS codes verified
  GENERATING       // Declaration being generated
  READY_TO_SUBMIT  // Declaration ready, awaiting submission
  SUBMITTING       // Playwright/NSW API in progress
  SUBMITTED        // Submitted to NSW/Customs
  NSW_PROCESSING   // NSW acknowledged, pending customs
  CUSTOMS_REVIEW   // Under กรมศุลกากร review
  CLEARED          // Cleared by customs
  COMPLETED        // Job fully closed
  REJECTED         // Rejected by NSW or Customs
}

enum TransportMode {
  SEA
  AIR
  LAND
  POST
}

// ใช้สิทธิประโยชน์ / ไม่ใช้ (field 3)
enum DeclarationType {
  WITH_PRIVILEGE     // ใช้สิทธิประโยชน์
  WITHOUT_PRIVILEGE  // ไม่ใช้สิทธิประโยชน์
}

enum SubmissionMethod {
  NSW_API    // National Single Window — ebXML over HTTPS
  PLAYWRIGHT // Direct portal automation
  CSV_EXPORT // Netbay CSV manual upload
}

enum SubmissionStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  RETRY
}

// ebXML Reliable Messaging — ack states (Section 6 of spec)
enum EbxmlAckStatus {
  WAITING    // AckRequested sent, no response yet
  RECEIVED   // Acknowledgment element received
  TIMEOUT    // TimeToLive expired without ACK
  FAILED     // Max retries exceeded
}

// NSW Status Response messageStatus values (Section 7.3.3)
enum NswMessageStatus {
  NOT_SENT        // Not submitted yet
  UN_AUTHORIZED   // UnAuthorized response from NSW
  NOT_RECOGNIZED  // NotRecognized — message not found
  RECEIVED        // NSW received message
  PROCESSED       // NSW processed declaration
  FORWARDED       // NSW forwarded to กรมศุลกากร
  CLEARED         // Customs cleared (our addition)
  REJECTED        // Customs rejected (our addition)
}

enum BillingItemType {
  DECLARATION_FEE
  AI_EXTRACTION_FEE
  NSW_SUBMISSION_FEE
  CUSTOMS_SERVICE_FEE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum DocumentType {
  COMMERCIAL_INVOICE
  PACKING_LIST
  BOOKING_CONFIRMATION
  EXPORT_DECLARATION
  NETBAY_CSV
  CUSTOMS_RECEIPT
  OTHER
}

enum HsVerificationStatus {
  AI_MATCHED   // AI found in master data
  AI_LOW_CONF  // AI matched but low confidence
  MANUAL       // User manually entered
  MISSING      // Not found, needs input
}

// ─── TENANT & USERS ───────────────────────────────────────────────

model Customer {
  id            String       @id @default(uuid())
  code          String       @unique @db.VarChar(10)  // e.g. "THEL"
  companyNameTh String       @db.VarChar(255)
  companyNameEn String?      @db.VarChar(255)

  // field 2: เลขประจำตัวผู้เสียภาษีอากร (13 digits)
  taxId         String       @unique @db.VarChar(15)

  // field 1: ที่อยู่
  address       String?      @db.Text
  postcode      String?      @db.VarChar(10)
  phone         String?      @db.VarChar(20)
  email         String?      @db.VarChar(255)

  // field 7: ตัวแทนออกของ (broker = service provider)
  brokerName    String?      @db.VarChar(255)
  brokerTaxId   String?      @db.VarChar(15)

  // field 5: ชื่อและเลขที่บัตรผ่านพิธีการ
  agentCardNo   String?      @db.VarChar(50)
  agentName     String?      @db.VarChar(255)

  // Billing config
  billingType   BillingType  @default(PER_JOB)
  termDays      Int?                                  // null if PER_JOB
  pricePerJob   Decimal      @default(450) @db.Decimal(10, 2)

  // Credentials for customs portal (AES-256 encrypted at rest)
  customsUsername    String?  @db.VarChar(255)
  customsPasswordEnc String?  @db.Text
  nswAgentCode       String?  @db.VarChar(50)
  customsExporterId  String?  @db.VarChar(50)

  // ebXML / NSW config — issued by NSW Thailand per agent (Section 3.1.2)
  nswCpaId        String?  @db.VarChar(200)  // CPAId — agreement ID from NSW
  nswPartyId      String?  @db.VarChar(200)  // Our PartyId (e.g. urn:duns:XXXXXXX)
  nswEndpointUrl  String?  @db.VarChar(500)  // NSW MSH endpoint URL
  nswSecurityProfile Int   @default(1)       // ebXML security profile (0=none, 1=sign)

  status        CustomerStatus @default(ACTIVE)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  users            CustomerUser[]
  jobs             LogisticsJob[]
  billingItems     BillingItem[]
  billingInvoices  BillingInvoice[]
  exporters        Exporter[]
  privilegeCodes   PrivilegeCode[]
  hsMasterItems    HsMasterItem[]
  consignees       Consignee[]
  nswSubmissions   NswSubmission[]

  @@index([taxId])
  @@index([code])
}

model CustomerUser {
  id        String   @id @default(uuid())
  customerId  String
  profileId String                                   // Supabase auth.users.id
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([customerId, profileId])
  @@index([customerId])
  @@index([profileId])
}

// Supabase auth profile
model Profile {
  id        String   @id                             // = Supabase auth.users.id
  email     String   @unique
  fullName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerUsers CustomerUser[]
  auditLogs   AuditLog[]
}

// ─── MASTER DATA ──────────────────────────────────────────────────

model HsMasterItem {
  id              String   @id @default(uuid())
  customerId        String
  hsCode          String   @db.VarChar(20)           // e.g. "8542.31.10"
  descriptionEn   String   @db.VarChar(500)
  descriptionTh   String   @db.VarChar(500)
  statisticsCode  String?  @db.VarChar(20)           // field 26: รหัสสถิติ
  statisticsUnit  String?  @db.VarChar(20)           // field 26: หน่วย e.g. "C62"
  dutyRate        Decimal  @default(0) @db.Decimal(5, 4)  // field 31
  isControlled    Boolean  @default(false)           // ต้องมีใบอนุญาต field 33
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, hsCode])
  @@index([customerId])
  @@index([customerId, hsCode])
}

model Exporter {
  id            String   @id @default(uuid())
  customerId      String
  nameTh        String   @db.VarChar(255)
  nameEn        String?  @db.VarChar(255)
  taxId         String   @db.VarChar(15)
  address       String?  @db.Text
  postcode      String?  @db.VarChar(10)
  phone         String?  @db.VarChar(20)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model PrivilegeCode {
  id          String   @id @default(uuid())
  customerId    String
  code        String   @db.VarChar(50)
  nameTh      String   @db.VarChar(255)
  nameEn      String?  @db.VarChar(255)
  type        String   @db.VarChar(50)              // "IEAT" | "BOI" | "FreeZone"
  taxBenefit  String?  @db.VarChar(255)
  refNumber   String?  @db.VarChar(100)
  expiryDate  DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Consignee {
  id          String   @id @default(uuid())
  customerId  String
  nameTh      String?  @db.VarChar(255)
  nameEn      String   @db.VarChar(255)
  country     String   @db.VarChar(100)
  countryCode String   @db.VarChar(5)
  address     String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs     LogisticsJob[]

  @@index([customerId])
}

// ─── LOGISTICS JOB ────────────────────────────────────────────────

model LogisticsJob {
  id        String     @id @default(uuid())
  customerId  String
  jobNo     String     @unique @db.VarChar(30)

  type      JobType    @default(EXPORT)
  status    JobStatus  @default(DRAFT)

  vesselName    String?  @db.VarChar(255)
  voyageNo      String?  @db.VarChar(50)
  transportMode TransportMode @default(SEA)

  etd           DateTime?
  eta           DateTime?

  portOfLoading     String?  @db.VarChar(100)
  portOfLoadingCode String?  @db.VarChar(10)
  portOfDischarge   String?  @db.VarChar(100)
  portOfReleaseCode String?  @db.VarChar(10)

  containerNo   String?  @db.VarChar(50)
  sealNo        String?  @db.VarChar(50)

  consigneeId     String?
  consigneeNameEn String? @db.VarChar(255)
  consigneeAddr   String? @db.Text

  totalFobUsd   Decimal? @db.Decimal(15, 2)
  totalFobThb   Decimal? @db.Decimal(15, 2)
  currency      String   @default("USD") @db.VarChar(5)

  nswRefNo      String?  @db.VarChar(100)
  customsRefNo  String?  @db.VarChar(100)

  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer        Customer            @relation(fields: [customerId], references: [id])
  consignee       Consignee?          @relation(fields: [consigneeId], references: [id])
  documents       JobDocument[]
  declarations    ExportDeclaration[]
  statusHistory   JobStatusHistory[]
  billingItem     BillingItem?
  nswSubmissions  NswSubmission[]

  @@index([customerId])
  @@index([customerId, status])
  @@index([jobNo])
  @@index([customerId, createdAt])
}

model JobStatusHistory {
  id         String    @id @default(uuid())
  jobId      String
  fromStatus JobStatus?
  toStatus   JobStatus
  changedBy  String
  note       String?   @db.Text
  createdAt  DateTime  @default(now())

  job LogisticsJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model JobDocument {
  id           String       @id @default(uuid())
  jobId        String
  customerId     String
  type         DocumentType
  fileName     String       @db.VarChar(255)
  fileUrl      String       @db.Text
  fileSizeKb   Int?
  mimeType     String?      @db.VarChar(100)
  uploadedById String
  createdAt    DateTime     @default(now())

  job LogisticsJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([customerId])
}

// ─── EXPORT DECLARATION — กศก.101/1 ──────────────────────────────

model ExportDeclaration {
  id        String @id @default(uuid())
  customerId  String
  jobId     String

  // field 4
  declarationNo    String?  @db.VarChar(50)

  // field 3
  declarationType  DeclarationType @default(WITH_PRIVILEGE)
  invoiceRef       String?  @db.VarChar(100)

  // field 5
  agentCardNo  String?  @db.VarChar(50)
  agentName    String?  @db.VarChar(255)

  // field 7
  brokerName   String?  @db.VarChar(255)
  brokerTaxId  String?  @db.VarChar(15)

  // field 8, 9
  totalDutyThb     Decimal? @db.Decimal(15, 2)
  securityDeposit  Decimal? @db.Decimal(15, 2)

  // field 11
  transportMode    TransportMode @default(SEA)

  // field 13
  dutyPaymentRef   String?  @db.VarChar(100)

  // field 14
  portOfRelease     String?  @db.VarChar(100)
  portOfReleaseCode String?  @db.VarChar(10)
  portOfLoading     String?  @db.VarChar(100)
  portOfLoadingCode String?  @db.VarChar(10)

  // field 15
  soldToCountry     String?  @db.VarChar(100)
  soldToCountryCode String?  @db.VarChar(5)

  // field 16
  destinationCountry String? @db.VarChar(100)
  destinationCode    String? @db.VarChar(5)

  // field 17
  totalPackages     Int?
  totalPackagesThai String?  @db.VarChar(200)

  // field 18 — from BoT API
  exchangeRate      Decimal? @db.Decimal(10, 4)
  exchangeCurrency  String?  @db.VarChar(5)
  exchangeRateDate  DateTime?

  // field 34
  officerNote  String? @db.Text

  // field 35
  totalFobThb  Decimal? @db.Decimal(15, 2)

  // field 37, 38
  signatoryName String?  @db.VarChar(255)
  signedAt      DateTime?
  submittedAt   DateTime?

  // ── XSD v4.00 — Exporter (auto-populated from Exporter master) ──────
  exporterTaxId    String?  @db.VarChar(17)   // Seq.3  Exporter/TaxNumber
  exporterBranch   String?  @db.VarChar(6)    // Seq.4  Exporter/Branch
  exporterNameTh   String?  @db.VarChar(120)  // Seq.5  Exporter/ThaiName
  exporterNameEn   String?  @db.VarChar(70)   // Seq.6  Exporter/EnglishName
  exporterAddress  String?  @db.VarChar(70)   // Seq.7  Exporter/StreetAndNumber

  // ── XSD v4.00 — Agent/Broker ────────────────────────────────────────
  agentBranch      String?  @db.VarChar(6)    // Seq.13 Agent/Branch

  // ── XSD v4.00 — AuthorisedPerson ────────────────────────────────────
  managerIdCard    String?  @db.VarChar(17)   // Seq.16 ManagerIDCard
  managerName      String?  @db.VarChar(35)   // Seq.17 ManagerName

  // ── XSD v4.00 — BorderTransportMeans ────────────────────────────────
  cargoTypeCode    String?  @db.VarChar(1)    // Seq.19 CargoTypeCode (UNECE Rec.21)
  vesselName       String?  @db.VarChar(35)   // Seq.20 VesselName (auto from job)
  departureDate    DateTime?                  // Seq.21 DepartureDate (auto from job.etd)

  // ── XSD v4.00 — Bill of Lading ──────────────────────────────────────
  masterBl         String?  @db.VarChar(35)   // Seq.22 BillofLading/Master
  houseBl          String?  @db.VarChar(35)   // Seq.23 BillofLading/House

  // ── XSD v4.00 — Package & Weight ────────────────────────────────────
  shippingMarks    String?  @db.VarChar(512)  // Seq.28 ShippingMarks
  packageUnitCode  String?  @db.VarChar(2)    // Seq.30 TotalPackage/UnitCode
  totalNetWeight   Decimal? @db.Decimal(11,3) // Seq.31 TotalNetWeight
  netWeightUnit    String?  @db.VarChar(3)    // Seq.32 NetWeightUnitCode
  totalGrossWeight Decimal? @db.Decimal(11,3) // Seq.33 TotalGrossWeight
  grossWeightUnit  String?  @db.VarChar(3)    // Seq.34 GrossWeightUnitCode

  // ── XSD v4.00 — FOB & Financial ─────────────────────────────────────
  totalFobForeign  Decimal? @db.Decimal(16,2) // Seq.37 FOBValue/Foreign
  paymentMethod    String?  @db.VarChar(1)    // Seq.45 PaymentMethod (a1)
  guaranteeMethod  String?  @db.VarChar(1)    // Seq.51 ObligationGuarantee/Method

  // ── XSD v4.00 — NSW / Reference ─────────────────────────────────────
  nswReferenceNumber    String?  @db.VarChar(13)  // Seq.1  ReferenceNumber (an13)
  declarationDocType    String?  @db.VarChar(1)   // Seq.2  DocumentType (default "E")
  nswRegistrationId     String?  @db.VarChar(35)  // Seq.66 RegistrationID (Sender ID)
  exportTaxIncentivesId String?  @db.VarChar(17)  // Seq.57 ExportTaxIncentivesID

  // Submission tracking
  submissionMethod SubmissionMethod?
  submissionStatus SubmissionStatus @default(PENDING)
  submissionRef    String?          @db.VarChar(100)
  submissionLog    String?          @db.Text

  // Playwright screenshots
  screenshotUrls   String[]

  // ── ebXML NSW Connector fields (v2.1) ──────────────────────────
  // ebXML MessageHeader — MessageData (Section 3.1.6)
  ebxmlMessageId      String?  @db.VarChar(255)  // globally unique, RFC2822 format
  ebxmlConversationId String?  @db.VarChar(255)  // ties related messages together
  ebxmlCpaId          String?  @db.VarChar(255)  // CPAId issued by NSW per agent

  // Reliable messaging state (Section 6)
  ebxmlAckStatus      EbxmlAckStatus @default(WAITING)
  ebxmlAckReceivedAt  DateTime?                  // when Acknowledgment arrived
  ebxmlRetryCount     Int            @default(0) // max 3 per spec Section 6.4.3
  ebxmlLastSentAt     DateTime?                  // for RetryInterval tracking

  // NSW StatusResponse (Section 7.3.3)
  nswMessageStatus    NswMessageStatus @default(NOT_SENT)
  nswStatusCheckedAt  DateTime?        // last StatusRequest poll timestamp

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job        LogisticsJob      @relation(fields: [jobId], references: [id])
  items      DeclarationItem[]
  nswSubmissions NswSubmission[]

  @@index([customerId])
  @@index([jobId])
  @@index([declarationNo])
  @@index([ebxmlMessageId])              // fast lookup by NSW message ref
  @@index([ebxmlAckStatus])             // find all WAITING/TIMEOUT submissions
  @@index([nswMessageStatus])           // dashboard filter by NSW status
}

// ─── NSW SUBMISSION LOG ───────────────────────────────────────────
// One record per attempt (including retries) — immutable audit trail
// Maps to ebXML Section 6: each send = one record

model NswSubmission {
  id              String   @id @default(uuid())
  customerId        String
  jobId           String
  declarationId   String

  // ebXML message identity
  ebxmlMessageId  String   @db.VarChar(255)  // matches ExportDeclaration.ebxmlMessageId
  attemptNo       Int      @default(1)        // 1, 2, 3 (max retries from spec)

  // Request details
  soapAction      String?  @db.VarChar(100)  // "ebXML"
  endpointUrl     String?  @db.VarChar(500)
  requestBody     String?  @db.Text           // full SOAP envelope (for debug)
  requestSentAt   DateTime

  // Response details
  httpStatusCode  Int?                        // 200, 500, etc.
  responseBody    String?  @db.Text           // raw response
  respondedAt     DateTime?

  // Acknowledgment (Section 6.3.2)
  ackStatus       EbxmlAckStatus @default(WAITING)
  ackReceivedAt   DateTime?
  ackRefMessageId String?  @db.VarChar(255)  // RefToMessageId from Acknowledgment

  // NSW message status (Section 7.3.3) after polling
  nswMessageStatus NswMessageStatus @default(NOT_SENT)
  nswTimestamp     DateTime?        // Timestamp from StatusResponse

  // Error details
  errorCode       String?  @db.VarChar(100)  // ebXML errorCode (e.g. SecurityFailure)
  errorSeverity   String?  @db.VarChar(20)   // Warning | Error
  errorLocation   String?  @db.VarChar(255)
  errorDetail     String?  @db.Text

  // Screenshot (Playwright / process log)
  screenshotUrl   String?  @db.Text

  createdAt DateTime @default(now())

  customer    Customer            @relation(fields: [customerId], references: [id])
  job         LogisticsJob      @relation(fields: [jobId], references: [id])
  declaration ExportDeclaration @relation(fields: [declarationId], references: [id])

  @@unique([declarationId, attemptNo])
  @@index([customerId])
  @@index([jobId])
  @@index([declarationId])
  @@index([ebxmlMessageId])
  @@index([ackStatus])
  @@index([createdAt])
}

// ─── DECLARATION ITEMS — กศก.101/1 line items ────────────────────

model DeclarationItem {
  id              String @id @default(uuid())
  declarationId   String
  customerId        String

  seqNo           Int

  packageMark     String?  @db.VarChar(255)
  packageQty      Int?
  packageType     String?  @db.VarChar(100)

  descriptionEn   String   @db.VarChar(500)
  descriptionTh   String?  @db.VarChar(500)
  brandName       String?  @db.VarChar(200)

  netWeightKg     Decimal? @db.Decimal(12, 4)

  quantity        Decimal  @db.Decimal(15, 4)
  quantityUnit    String   @db.VarChar(20)

  hsCode          String   @db.VarChar(20)
  hsVerification  HsVerificationStatus @default(MISSING)
  hsConfidence    Float?

  statisticsCode  String?  @db.VarChar(20)
  statisticsUnit  String?  @db.VarChar(20)

  fobForeign      Decimal  @db.Decimal(15, 4)
  fobCurrency     String   @default("USD") @db.VarChar(5)
  fobThb          Decimal? @db.Decimal(15, 2)

  dutyAssessValue Decimal? @db.Decimal(15, 2)

  privilegeCode   String?  @db.VarChar(50)
  privilegeRef    String?  @db.VarChar(100)

  dutyRate        Decimal  @default(0) @db.Decimal(5, 4)
  exportDutyThb   Decimal? @db.Decimal(15, 2)

  exportLicenseNo     String?  @db.VarChar(100)
  exportLicenseIssuer String?  @db.VarChar(200)
  exportLicenseDate   DateTime?
  exportLicenseExpiry DateTime?

  sourceInvoiceNo   String? @db.VarChar(50)
  sourceProductCode String? @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  declaration ExportDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@index([declarationId])
  @@index([customerId])
  @@index([customerId, hsCode])
  @@unique([declarationId, seqNo])
}

// ─── BILLING ──────────────────────────────────────────────────────

model BillingItem {
  id        String          @id @default(uuid())
  customerId  String
  jobId     String          @unique
  type      BillingItemType @default(DECLARATION_FEE)

  amount    Decimal         @db.Decimal(10, 2)
  currency  String          @default("THB") @db.VarChar(5)

  isInvoiced Boolean        @default(false)
  invoiceId  String?

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  customer  Customer          @relation(fields: [customerId], references: [id])
  job     LogisticsJob    @relation(fields: [jobId], references: [id])
  invoice BillingInvoice? @relation(fields: [invoiceId], references: [id])

  @@index([customerId])
  @@index([customerId, isInvoiced])
}

model BillingInvoice {
  id        String        @id @default(uuid())
  customerId  String
  invoiceNo String        @unique @db.VarChar(30)

  totalAmount Decimal     @db.Decimal(12, 2)
  currency    String      @default("THB") @db.VarChar(5)

  status      InvoiceStatus @default(DRAFT)
  dueDate     DateTime?
  paidAt      DateTime?

  periodStart DateTime?
  periodEnd   DateTime?
  note        String?     @db.Text

  issuedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  customer  Customer        @relation(fields: [customerId], references: [id])
  items   BillingItem[]

  @@index([customerId])
  @@index([customerId, status])
}

// ─── AUDIT LOG (ISO 27001 A.8.15) ────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  customerId   String?
  actorId    String?
  actorEmail String?  @db.VarChar(255)
  action     String   @db.VarChar(100)
  entityType String?  @db.VarChar(50)
  entityId   String?  @db.VarChar(50)
  ipAddress  String?  @db.VarChar(50)
  userAgent  String?  @db.Text
  detail     Json?
  createdAt  DateTime @default(now())

  actor Profile? @relation(fields: [actorId], references: [id])

  @@index([customerId])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
