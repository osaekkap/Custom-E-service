# Supabase Local Development
# Run `npx supabase start` to get these values (Docker Desktop must be running first)

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_32"

SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_ANON_KEY="your-supabase-anon-key"

PORT=3000
NODE_ENV=development

# NSW Connector (ebXML)
NSW_ENDPOINT="http://localhost:18080/nsw/mock"
NSW_CPA_ID="CUSTOMS-EDOC-CPA-DEV"
NSW_FROM_PARTY_ID="urn:customs-edoc:dev"
NSW_TO_PARTY_ID="urn:duns:customs.go.th"

ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
